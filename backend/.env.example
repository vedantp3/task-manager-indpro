# ─────────────────────────────────────────────
# Backend environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Supabase PostgreSQL connection string
# Found in: Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=

# Secret key for signing JWTs — use a random 32+ char string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT expiry duration (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# Port the server listens on
PORT=5000

# Allowed frontend origin for CORS
# Local dev: http://localhost:5173
# Production: your Vercel URL e.g. https://taskmanager.vercel.app
CLIENT_ORIGIN=http://localhost:5173
